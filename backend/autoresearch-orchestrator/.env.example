# Autoresearch Orchestrator — environment template.
# Copy to .env and fill in real values for the *required* section.
#
# config.py reads plain environment variables (it does NOT auto-load .env).
# Load this file into your shell before running, e.g.:
#   set -a; source .env; set +a
#   python main.py "your goal"
#   python main.py --experiment-repo /path/to/autoresearch

# =============================================================================
# REQUIRED
# =============================================================================

# Model provider key. The default model is `openai:gpt-5.4`, so an OpenAI key is
# needed unless you change AUTORESEARCH_MODEL to an Anthropic/Google model below.
OPENAI_API_KEY=sk-replace-me
# ANTHROPIC_API_KEY=sk-ant-replace-me        # needed if AUTORESEARCH_MODEL=anthropic:...
# GOOGLE_API_KEY=replace-me                  # needed if AUTORESEARCH_MODEL=google_genai:...

# Modal credentials for the Builder/Scientist/Developer sandboxes (general mode).
# Easiest: run `modal setup` once (writes ~/.modal.toml). Otherwise set tokens here.
# Not needed for experiment mode (--experiment-repo runs code locally).
# MODAL_TOKEN_ID=ak-replace-me
# MODAL_TOKEN_SECRET=as-replace-me

# =============================================================================
# CORE SWARM (sensible defaults shown)
# =============================================================================
AUTORESEARCH_APP_NAME=autoresearch-swarm
AUTORESEARCH_MODEL=openai:gpt-5.4
AUTORESEARCH_WORKSPACE=.autoresearch_workspace
AUTORESEARCH_MAX_GENERATIONS=3
DISTILLED_BRIEF_WORD_LIMIT=500

# Hierarchy: PI -> parallel Scientist+Developer workers -> Reviewer
AUTORESEARCH_MAX_WORKERS=3
AUTORESEARCH_WORKER_CONCURRENCY=3
AUTORESEARCH_REVIEWER_ENABLED=true
AUTORESEARCH_REVIEW_PASS_SCORE=0.7

# Research ledger (long-term memory of attempted approaches)
AUTORESEARCH_LEDGER_ENABLED=true
AUTORESEARCH_LEDGER_SIMILARITY=0.8

# Diagnostic sub-loop (environment self-repair before abandoning a worker)
AUTORESEARCH_DIAGNOSTIC_ENABLED=true
AUTORESEARCH_DIAGNOSTIC_ATTEMPTS=1

# =============================================================================
# EXPERIMENT MODE (program.md keep/discard loop, e.g. karpathy/autoresearch)
# =============================================================================
AUTORESEARCH_EXPERIMENT_TIMEOUT=600        # per-run kill ceiling (seconds)
AUTORESEARCH_MAX_EXPERIMENTS=100           # budget of keep/discard iterations
AUTORESEARCH_EXPERIMENT_BRANCH=            # optional git branch, e.g. autoresearch/may30
AUTORESEARCH_EXPERIMENT_LITERATURE=false

# =============================================================================
# MODAL SANDBOX (general mode code execution)
# =============================================================================
MODAL_APP_NAME=autoresearch-swarm-runtime
MODAL_TIMEOUT_SECONDS=300
MODAL_PYTHON_VERSION=3.12

# =============================================================================
# RAINDROP TELEMETRY (raw traces stay out of agent context)
# =============================================================================
RAINDROP_ENABLED=true                      # set false in tests / offline runs
RAINDROP_API_KEY=                          # bearer token for the ingestion API
RAINDROP_BASE_URL=http://127.0.0.1:8080
RAINDROP_PROJECT=autoresearch-swarm

# =============================================================================
# LITERATURE REVIEW (Filter agent: arXiv, Scholar, CrossRef, Semantic Scholar)
# =============================================================================
LITERATURE_ARXIV_MAX_RESULTS=8
LITERATURE_SCHOLAR_MAX_RESULTS=5
LITERATURE_SCHOLAR_ENABLED=true
LITERATURE_ENRICH_CITATIONS=true
LITERATURE_SEMANTIC_SCHOLAR_ENABLED=true
LITERATURE_CROSSREF_ENABLED=true
LITERATURE_CROSSREF_MAILTO=samivader@gmail.com
LITERATURE_S2_REFERENCE_LIMIT=3
