# AutoLab backend environment — copy this file to `.env` and fill in values.
#   cp .env.example .env

# Port the API listens on
PORT=4000

# Secret used to sign JWTs. Generate a strong one, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=replace-with-a-long-random-secret
